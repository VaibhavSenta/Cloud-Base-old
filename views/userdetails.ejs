<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home - Cloude Base</title>
    <style>
        * {
            font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
            box-sizing: border-box;
            list-style: none;
            text-decoration: none;

            margin: 0;
            padding: 0;

            color: rgba(255, 255, 255, 0.899);

            transition: all 0.3s ease-in-out;
            cursor: default;
        }

        ::-webkit-scrollbar{
            background-color: transparent;
            width: 8px;
        }
        ::-webkit-scrollbar-track{
            background-color: transparent;
        }

        ::-webkit-scrollbar-thumb{
            background-color: rgba(76, 76, 76, 0.62);
            border-radius: 50px;
        }
        a,button {
            cursor: pointer;

            outline: none;
            border: none;
        }
        
        
        /* body {
            display: flex;
            align-items: center;
            flex-direction: column;
            justify-content: flex-start;

            position: relative;

            padding: 2vh 1vw;

            background-color: black;
        }  */

        nav{
            display: flex;
            flex-direction: row;
            align-items: center;
            justify-content: space-between;
            

            position: sticky;
            z-index: 1;

            background-color: inherit;
            width: 100vw;

            top: 0px;

            padding: 16px 8px;

            border-radius: 10px;

        }

        .profileLogo{
            display: flex;
            flex-direction: row;

            background-color: transparent;

            height: 100%;
            width: auto;

        }
        .profileLogo button {
            background-color: slateblue;

            color: white;
            
            padding: 10px;

            margin-right: 30px;

            border-radius: 5px;

            box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.567);
            outline: none;
            border: none;

        }
        .profileLogo button a {
            color: inherit;
            text-decoration: none;
            font-size: 1rem;
        }

        nav> h1 {
            font-size: 30px;
        }

        body>:nth-child(2){


            /* margin-top: 14vh; */
        }















































        body{
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: space-between;

            background-color: black;

            overflow: hidden;

            width: 100vw;
            height: 100vh;

            padding: 10px;
        }


        main{
            display: flex;
            flex-direction: row;
            align-items: center;
            justify-content: space-between;

            position: relative;
            
            background-color: transparent;
            
            width: 100%;
            height: 100%;

        }
        
        .center{
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content:flex-start;

            position: relative;

            background-color: rgba(14, 14, 14, 0);

            /* background-color: transparent; */
            border-radius: 20px;

            width: 100%;
            height: 100%;

            margin: 5px;

            /* overflow-y: auto; */
            overflow: auto;
        }
        .center header {
            width: 100%;
            font-size: 30px;
            font-weight: 700;
            text-decoration: underline;
            background-color: transparent;
        }

        
        .section1 >img{
            width: 100%;
            height: 70%;
            object-fit: fill;
            filter: blur(90px) contrast(100%) brightness(90%);
            opacity: 0.5;
            position: absolute;
        }










        .section1 {
            display: flex;
            flex-direction: row;
            align-items:center ;
            justify-content: center;

            position: relative;

            background-color: transparent;

            width: 100%;
            height: max-content;
            
        }
        
        .part1, .part2{
            margin: 20px;
        }
        .part1{
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: center;

            width: 300px;
            height: max-content;
            position: relative;

            background-color: transparent;

            padding: 20px;

        }
        .part1 img{
            width: 100px;
            width: 100%;
            max-width: 240px;
            /* height: 100%; */
            /* aspect-ratio: 2/3; */
            object-fit: contain;
            position: relative;

            box-shadow: 20px 20px 25px rgba(0, 0, 0, 0.557);
            z-index: 3;
            
            margin: 40px 0px 0;
            
        }

        .part2{
            display: flex;
            flex-wrap: wrap;
            flex-direction: column;
            justify-content: center;

            /* padding: 0px 30px; */

            text-wrap: wrap;
            width: 400px;
            height: auto;
            /* position: relative;
            overflow: auto; */
            background-color: transparent;
        }


        .part2 div {
            display: flex;
            flex-direction: column;
            width: 100%;
            text-wrap: wrap;
            margin: 10px;
        }
        .part2 div p{
            display: flex;
            flex-wrap: wrap;
            text-wrap: wrap;
            align-items: center;
        }
        .part2 div p label{
            font-size: 1.3rem;
            font-weight: 700;
        }


        div[class="btn"]{
            display: flex;
            align-items: center;
            justify-content: space-evenly;
            position: relative;

            flex-direction: row;
            width: 100%;

            cursor: pointer;
            background-color: transparent;
        }
        button[type="submit"]{
            font-size: 1.4rem;
            background-color: rgb(50, 116, 89);
            padding: 10px;
            border: none;
            outline: none;
            width: max-content;
            border-radius: 6px;
            cursor: pointer;
            z-index: 2;

        }

        button[class="button"]{
            margin: 4px;
            width: max-content;
            cursor: pointer;
            
        }
        form[class="button"]{
            width: max-content;
            margin: 4px;
            background-color: aliceblue;
            cursor: pointer;
            position: relative;
        }



        .part3{
            background-color: rgba(33, 33, 33, 0.516);

            display: flex;
            align-items: flex-start;
            justify-content: flex-start;
            flex-direction: column;

            padding: 20px;

            border-radius: 15px;

            box-shadow: 30px 20px 30px -20px black;
            margin: 10px;


        }
        .part3 h3{
            width: 100%;
            text-align: center;

            font-size: 27px;
            margin-bottom: 30px;
        }
        .part3 div{
            display: flex;
            flex-direction: row;
            align-items: center;
            width: 100%;
            background-color: transparent;
        }
        .part3 div label{
            font-size: 19px;
            font-weight: 700;
        }

        .part3 div p{
            color: rgb(240, 137, 10);

            padding-left: 10px;
        }

        .section2{
            display: flex;
            flex-direction: column;

            align-items: center;
            justify-content: center;

            position: relative;

            background-color: transparent;
            width: 100%;
            height: max-content;

            /* overflow: auto; */

        }
        







































        .movieContainer{
            display: flex;
            flex-direction: row;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-evenly;

            background-color: transparent;

            width: 100%;

            padding: 2px;

        }

        .allDetails {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        flex-wrap: wrap;
        flex-direction: row;

        width: 100%;
        height: 100%;
      }
      .movieCard {
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        align-items: center;

        position: relative;
        background-color: rgb(44, 44, 44);

        border: 2px solid transparent;
        border-radius: 15px;

        /* min-width: 100px; */
        /* max-width: 510px; */
        width: 48%;
        height: max-content;

        /* aspect-ratio: 2/3; */

        margin: 10px;
        padding: 10px;
        

        overflow: hidden;
        box-shadow: 20px 20px 30px -5px rgba(0, 0, 0, 0.427);

        &:hover {
          box-shadow: 40px 40px 40px -20px rgba(0, 0, 0, 0.87);
          border-color: rgba(219, 219, 219, 0.732);
          transform: scale(1.01);
          cursor: pointer;
        }
      }

      .movieCard img {
        width: inherit;
        aspect-ratio: inherit;
        object-fit: cover;
        position: relative;
      }

      .text {
        display: flex;
        flex-direction: column;
        flex-wrap: wrap;
        align-items: center;
        text-align: center;

        position: absolute;
        background: linear-gradient(
          to top,
          rgb(0, 0, 0) 10%,
          rgba(253, 253, 253, 0) 90%
        );

        width: 100%;
        height: 100%;
        

        padding: 6px;

        text-shadow: 2px 1px 3px black;

        &:hover {
          cursor: pointer;
        }
      }
      .keyValue {
        display: flex;
        align-items: flex-start;
        justify-content: flex-start;

        background-color: transparent;

        width: 100%;
        height: auto;

        font-size: 18px;
      }
      .keyName {
        color: rgb(237, 237, 237);
        font-weight: 600;
        font-size: 16px;
      }
      .value {
        color: rgb(148, 77, 10);
        font-weight: 500;
        font-size: 18px;
        text-wrap: wrap;
      }
      .movieCard a {
        position: absolute;
        bottom: 0;
        width: 100%;
        height: 100%;
        z-index: 3;

        background-color: transparent;
      }


        
    </style>
    <% if (vercelSpeedInsights) { %>
    <!-- Vercel Speed Insights -->
    <script>
    (function() {
        // Initialize Vercel Speed Insights for page performance monitoring
        // This script runs on the client side only
        import('@vercel/speed-insights').then(({ injectSpeedInsights }) => {
            injectSpeedInsights();
        }).catch(err => {
            // Speed Insights failed to load - this is non-critical
            console.debug('Speed Insights initialization failed:', err);
        });
    })();
    </script>
    <% } %>

</head>
<body>
    
    <nav>

        <h1>Cloude Base Admin</h1>
    
        <div class="profileLogo">

            <!-- <button>
                
                <a href="/upload"> Upload </a>
                <a href="">vaibhav999</a>
            </button> -->

            <button>
                
                <a href="/<%= adminName %>"> <%= adminName %> </a>
                <!-- <a href="">vaibhav999</a> -->
            </button>
            
        </div>

    </nav>

    <main>
        <div class="center">
            <!-- <img src="../uploads/1731811786723.jpg" alt=""> -->
            
            <header>User details</header>
            <section class="section1">
                <img src="<%= detail.profilePic %>" alt="movieCard">

             
                <div class="part1">
                        
                    <!-- <img src="../uploads/1731811786723.jpg" alt="adh"> -->
                    <img src="<%= detail.profilePic %>" alt="movieCard">
              
                </div>
                <div class="part2">

                    <div>

                        <h1><%= detail.email %></h1>
                        <p> Username : <%= detail.userName %></p>
                        <p>Recovery email : <%= detail.recoveryEmail %></p>
                    </div>

                    <div>
                        
                        <ul>
                            <!-- <li>Genre: Action</li> -->
                            <li>First name: <%= detail.firstName %></li>
                            <li>Last name: <%= detail.lastName %></li>
                            <li>Gender: <%= detail.gender %></li>
                            <li>Size: <%= detail.couentryCode %></li>
                            <li>Phone number: <%= detail.phonenumber %></li>
                            <li>dob in: <%= detail.dob %></li>
                            
                        </ul>
                    </div>


                    <div>
                        <p><label >Account ststus: </label> <%= detail.accountStatus %></p>
                        <p><label>logedinDevices :</label> <%= detail.detaillogedinDevices %></p>
                        <p><label>Created at: </label><%= detail.createdAt %></p>
                        <p><label>Updated at :</label><%= detail.updatedAt %></p>
                    </div>

                    <div class="btn">
                        <!-- <but   ton class="button" type="submit"><a href="/admin/allusers/edit/<%= detail.email %>">Edit details</a></but> -->

                        <form action="/admin/allusers/user/delete" method="POST">
                            
                            <input type="email" name="email" id="email" value="<%= detail.email %>" hidden>
                            <button type="submit" > Delete from database </button>
                        </form>
                        
                    </div>
    
                </div>
                <div class="part3">

                    <h3>signup device detail</h3>
                    <% if (signupKeys.length > 0) { %>
                     
        
        
                        <% signupKeys.forEach(key => { %>
                            
                            <div>
                                <label><%= key %> : </label> <p> <%= signup[key] %> </p>
                            </div>
        
                        <% }) %>
        
        
        
                    <% } else { %>
                     
                        <p>No signup device details found.</p>
        
                    <% } %>

                </div>
            </section>

            <section class="section2">
                <header>Login from devices</header>
                <div class="allDetails">

                    <!-- <% loginDevices.forEach(device => { %> -->
            
                    <div class="movieCard">
                        <% loginKeyNames.forEach(key=> { %>
                        
                            <div class="keyValue">
                            <p class="keyName"><%= key %></p>
                            &nbsp; &nbsp; &nbsp; : &nbsp;
                            <p class="value"><%= device[key] %></p>
                            </div>
                
                            <a href="#"></a>
                        <% }) %>
                    </div>
            
                    <!-- <% }) %> -->
                </div>
            </section>
        </div>
    </main>

    
    
</body>
</html>