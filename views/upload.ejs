<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Upload on Cloude Base</title>
    <% if (vercelSpeedInsights) { %>
    <!-- Vercel Speed Insights -->
    <script>
    (function() {
        // Initialize Vercel Speed Insights for page performance monitoring
        // This script runs on the client side only
        import('@vercel/speed-insights').then(({ injectSpeedInsights }) => {
            injectSpeedInsights();
        }).catch(err => {
            // Speed Insights failed to load - this is non-critical
            console.debug('Speed Insights initialization failed:', err);
        });
    })();
    </script>
    <% } %>

</head>
<body>
    
    <h1>Upload files on Cloude Base</h1>

    <form action="/upload" method="post">

        <p>Select type of file you want to upload</p>

        <select name="categori" id="categori" required>
            <option value="movie">Movie</option>
            <!-- <option value="trailer">Trailer</option> -->
            <!-- <option value="tvshow">TV Show</option> -->
            <!-- <option value="cartoon">Cartoon</option> -->
            <!-- <option value="webseries">Web Series</option> -->
            <!-- <option value="song">Song</option> -->
            <!-- <option value="software">Software</option> -->
            <!-- <option value="operatingsystem">OS (Operating System)</option> -->
            <!-- <option value="image">Image</option> -->
            <!-- <option value="news">News</option> -->
            <!-- <option value="app">app</option> -->
            <option value="game">Game</option>
             
            
            
            
        </select>

        <button type="submit">Done</button>
    </form>

</body>
</html>